# All settings are optional. Defaults are sensible for local use.

# Where SQLite + blob storage live
WEBSTALKER_DATA_DIR=data

# Bind address for `uvicorn webstalker.main:app`
WEBSTALKER_BIND_HOST=127.0.0.1
WEBSTALKER_BIND_PORT=8000

# HTTP fetching
WEBSTALKER_REQUEST_TIMEOUT_SECONDS=30
WEBSTALKER_ASSET_TIMEOUT_SECONDS=15
WEBSTALKER_MAX_ASSET_SIZE_BYTES=5242880
WEBSTALKER_MAX_ASSETS_PER_PAGE=50
WEBSTALKER_USER_AGENT=WebStalker/0.1

# Set to false to disable APScheduler (useful for tests / migrations)
WEBSTALKER_ENABLE_SCHEDULER=true
